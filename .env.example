# Required for the internal API that talks to Ollama.
OLLAMA_BASE_URL="http://localhost:11434"

# Optional: override primary Ollama model used by the server.
OLLAMA_MODEL="qwen2.5:7b-instruct"

# Optional: comma-separated fallback models if primary model is unavailable.
OLLAMA_MODEL_FALLBACKS="llama3.1:8b-instruct,mistral:7b-instruct"

# Optional: timeout request ke Ollama dalam milidetik (default 300000 = 5 menit).
OLLAMA_TIMEOUT_MS="300000"

# Optional: mode cepat untuk endpoint /api/generate (semakin kecil semakin cepat, kualitas bisa turun).
OLLAMA_GENERATE_NUM_PREDICT="300"
OLLAMA_GENERATE_MAX_WORDS="220"
OLLAMA_GENERATE_VIDEO_PROMPTS="2"

# Optional: fallback token for workflow clip generation (used if dashboard field is empty).
HUGGINGFACE_TOKEN=""

# Optional: Replicate video generation. If set, generate_clips.py uses this before ComfyUI/local/HF.
REPLICATE_API_TOKEN=""
REPLICATE_MODEL="lightricks/ltx-video"
REPLICATE_USD_PER_SECOND="0.000975"
REPLICATE_ESTIMATED_SECONDS_PER_RUN="22"
REPLICATE_ESTIMATED_USD_PER_RUN="0.021"
VIDGEN_USD_TO_IDR="17000"

# Optional: ComfyUI API integration for remote visual generation.
COMFYUI_API_URL=""
COMFYUI_API_KEY=""
COMFYUI_WORKFLOW_FILE=""
COMFYUI_POLL_INTERVAL="3"
COMFYUI_TIMEOUT="900"

# Optional: local video generation endpoint (for ComfyUI/Wan/LTX wrapper or similar service).
VIDEO_MODEL_URL=""

# Recommended: keep these false in production so jobs fail instead of silently producing stock/test/black video.
VIDGEN_ALLOW_VISUAL_FALLBACK="false"
VIDGEN_ALLOW_BLACK_VIDEO_FALLBACK="false"

# Optional: change the integrated app port.
PORT="3000"

# Optional but recommended: move production queue off Firestore into PostgreSQL.
# If configured, server-side queue/retry/callback/dispatch will use PostgreSQL instead of Firestore.
# n8n self-hosted juga resmi kompatibel dengan PostgreSQL, jadi ini jalur yang disarankan.
VIDGEN_QUEUE_DB="postgres"
VIDGEN_POSTGRES_URL="postgresql://postgres:password@127.0.0.1:5432/vidgen"
# Alternative libpq-style vars if VIDGEN_POSTGRES_URL is empty:
# PGHOST="127.0.0.1"
# PGPORT="5432"
# PGDATABASE="vidgen"
# PGUSER="postgres"
# PGPASSWORD="password"

# Optional: default n8n production webhook used by the server when the UI setting is empty.
N8N_WEBHOOK_URL="https://n8n.example.com/webhook/vidgen-production"

# Optional: shared secret sent from the app server to n8n in header x-vidgen-webhook-secret.
N8N_WEBHOOK_SECRET=""

# Required if you want n8n callbacks to update Firestore queue status.
VIDGEN_CALLBACK_SECRET="replace-with-a-long-random-secret"

# Required for server-side Firestore access (pick one style below).
# FIREBASE_SERVICE_ACCOUNT_JSON='{"project_id":"...","client_email":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"}'
# or:
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional: use a non-default Firestore database ID (if your project does not use "(default)").
FIRESTORE_DATABASE_ID=""
